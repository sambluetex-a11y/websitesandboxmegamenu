<div class="featured-row section-standard {% unless section.settings.section_padding %}no-border{% endunless %}" data-section-id="{{ section.id }}" data-section-type="featured-row-section">
  <div class="contain-site-width {% unless section.settings.section_padding %}no-padding{% endunless %}">
    <div class="wrapper">

      <div class="feature-row">
        {% capture image_grid_item %}
          <div class="feature-row__item feature-row__image">
            {%- assign video = section.settings.youtube_url -%}
            {% if video != blank %}
              <div class="card__image-wrapper" style="padding-top:{{ 1 | divided_by: section.settings.aspect_ratio | times: 100}}%">
                <iframe 
                    width="100%" 
                    height="100%" 
                    src="{{ section.settings.youtube_url | replace: 'watch?v=', 'embed/' }}?autoplay={{ section.settings.autoplay | default: 0 }}&mute={{ section.settings.mute | default: 0 }}&loop={{ section.settings.loop | default: 0 }}&playlist={{ section.settings.youtube_url | split: 'v=' | last }}"
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                    allowfullscreen
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
                </iframe>
              </div>
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        {% endcapture %}

        {% if section.settings.layout == 'left' %}
            {{ image_grid_item }}
        {% endif %}

        <div class="feature-row__item feature-row__text feature-row__text--{{ section.settings.layout }} feature-row__text--align__{{ section.settings.text_align }}">
          {% if section.settings.title != blank %}
            <h3>{{ section.settings.title | escape }}</h3>
          {% endif %}
          {% if section.settings.text != blank %}
            <div class="rte">
              {{ section.settings.text }}
            </div>
          {% endif %}
          {% if section.settings.button_label != blank and section.settings.button_link != blank %}
            <a href="{{ section.settings.button_link }}" class="button outline">
              {{ section.settings.button_label | escape }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.layout == 'right' %}
            {{ image_grid_item }}
        {% endif %}

      </div>
    </div>
  </div>
</div>

<style>
  .video-wrapper {
    position: relative;
    width: 100%;
  }
</style>


{% schema %}
{
  "name": "Video with text",
  "class": "featured-row-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "section_padding",
      "label": "Show spacing around section",
      "default": true
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Video on left"
        },
        {
          "value": "right",
          "label": "Video on right"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Video with text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair large text with a video to give focus to your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },

     {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube Video URL",
      "info": "Enter the full YouTube video URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "range",
      "id": "video_width",
      "min": 300,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "label": "Video Width",
      "default": 800
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "options": [
        { "value": "1.7778", "label": "16:9" },
        { "value": "1.3333", "label": "4:3" },
        { "value": "2.4", "label": "21:9" }
      ],
      "label": "Aspect Ratio",
      "default": "1.7778"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay Video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute Video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop Video",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Video with text",
      "category": "Custom"
    }
  ]
}
{% endschema %}
